### LLM
# Either works; GOOGLE_API_KEY is preferred if both set
GEMINI_API_KEY=
GOOGLE_API_KEY=

### SerpAPI (Amazon search crawl for /api/pipeline/amazon-ingest)
SERPAPI_API_KEY=

### GLiNER (local NER on compressed items; first run downloads the HF model)
POPSIGHT_GLINER_ENABLED=true
# Light default; switch to urchade/gliner_multi-v2.1 for heavier multilingual coverage
POPSIGHT_GLINER_MODEL_ID=urchade/gliner_small-v2.1
POPSIGHT_GLINER_THRESHOLD=0.35
POPSIGHT_GLINER_MAX_INPUT_CHARS=1500
POPSIGHT_GLINER_BATCH_SIZE=8
# How many items print full request/response/merged JSON to stdout + INFO logs
POPSIGHT_GLINER_CONSOLE_SAMPLES=3

### App
APP_URL=http://localhost:8000
POPSIGHT_AUTO_BOOTSTRAP_MACROS=false

### Database (leave empty to use SQLite at data/popsight.db)
POPSIGHT_DATABASE_URL=

### Qdrant (optional; used when you add vector features)
POPSIGHT_QDRANT_URL=http://localhost:6333
POPSIGHT_QDRANT_API_KEY=

