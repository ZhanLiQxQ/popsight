### LLM
# Either works; GOOGLE_API_KEY is preferred if both set
GEMINI_API_KEY=
GOOGLE_API_KEY=

### App
APP_URL=http://localhost:8000
POPSIGHT_AUTO_BOOTSTRAP_MACROS=false

### Database (leave empty to use SQLite at data/popsight.db)
POPSIGHT_DATABASE_URL=

### Qdrant (optional; used when you add vector features)
POPSIGHT_QDRANT_URL=http://localhost:6333
POPSIGHT_QDRANT_API_KEY=

